FLASK_ENV=development
SECRET_KEY=supersecret

# Untuk lokal (MySQL via XAMPP/Laragon):
DATABASE_URL=mysql+pymysql://root:@localhost:3306/klasifikasi_db

# Untuk Docker:
# DATABASE_URL=mysql+pymysql://user:password@db:3306/klasifikasi_db
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=klasifikasi_db
MYSQL_USER=user
MYSQL_PASSWORD=password
