# Virtual Environment (Wajib karena sudah ada folder venv)
venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Database (Jika nanti kamu pakai SQLite, filenya jangan diupload)
*.db
*.sqlite3

# IDE Settings
.vscode/
.idea/

# OS metadata
.DS_StoreFROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 5000

CMD ["gunicorn", "--reload", "-b", "0.0.0.0:5000", "app:app"]
Thumbs.db

# Env files (Jika nanti kamu buat file .env untuk Secret Key)
.env